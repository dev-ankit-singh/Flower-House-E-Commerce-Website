<!-- TOAST -->
<div class="cart-toast" id="viewToast">
  <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
  <span id="viewToastMsg"></span>
</div>

<script>
  // Filter
  document.querySelectorAll('.vf-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.vf-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const cat = btn.dataset.cat;
      const cards = document.querySelectorAll('.vp-card');
      let visible = 0;
      cards.forEach(card => {
        const show = cat === 'all' || card.dataset.cat === cat;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      document.getElementById('viewEmpty').style.display = visible === 0 ? 'block' : 'none';
    });
  });

  // Cart toast
  function addToCart(name) {
    const toast = document.getElementById('viewToast');
    document.getElementById('viewToastMsg').textContent = name + ' added to cart!';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
  }
</script>

