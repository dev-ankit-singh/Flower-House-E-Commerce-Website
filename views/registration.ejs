<%-include('common/header')%>

    <section class="auth-section">
  <div class="auth-left">
    <div class="auth-left-content">
      <span class="auth-eyebrow">Welcome to Verduxe</span>
      <h2 class="auth-tagline">Join the world of <em>Premium Living</em></h2>
      <p>Create your account and get access to exclusive offers, early launches, and personalised recommendations for your living space.</p>
      <div class="auth-perks">
        <div class="auth-perk">
          <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Exclusive member-only discounts</span>
        </div>
        <div class="auth-perk">
          <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Track orders & easy returns</span>
        </div>
        <div class="auth-perk">
          <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          <span>Early access to new arrivals</span>
        </div>
      </div>
    </div>
  </div>

  <div class="auth-right">
    <div class="auth-form-card">
      <h1 class="auth-form-title">Create Account</h1>
      <p class="auth-form-sub">Already have an account? <a href="login">Sign in</a></p>

      <form action="/registration" method="post" class="auth-form" id="regForm">
        <div class="auth-row">
          <div class="auth-field">
            <label for="FirstName">First Name</label>
            <input type="text" name="FirstName" id="FirstName" placeholder="First name" required>
          </div>
          <div class="auth-field">
            <label for="LastName">Last Name</label>
            <input type="text" name="LastName" id="LastName" placeholder="Last name" required>
          </div>
        </div>
        <div class="auth-field">
          <label for="RegEmail">Email</label>
          <input type="email" name="Email" id="RegEmail" placeholder="your@email.com" required>
        </div>
        <div class="auth-field">
          <label for="Phone">Phone Number</label>
          <input type="tel" name="Phone" id="Phone" placeholder="+91 XXXXX XXXXX" required>
        </div>
        <div class="auth-field">
          <label for="Password">Password</label>
          <input type="password" name="Password" id="Password" placeholder="Create a strong password" required>
        </div>
        <div class="auth-field">
          <label for="CPassword">Confirm Password</label>
          <input type="password" name="CPassword" id="CPassword" placeholder="Repeat your password" required>
        </div>
        <p class="auth-error" id="regError"></p>
        <button type="submit" class="auth-submit">Create Account</button>
      </form>
    </div>
  </div>
</section>

<script>
  document.getElementById('regForm').addEventListener('submit', function(e) {
    const pw = document.getElementById('Password').value;
    const cpw = document.getElementById('CPassword').value;
    const err = document.getElementById('regError');
    if (pw !== cpw) {
      e.preventDefault();
      err.textContent = 'Passwords do not match.';
    } else { err.textContent = ''; }
  });
</script>

    <%-include('common/footer')%>