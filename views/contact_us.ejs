  <div class="contact-hero-overlay">
    <span class="page-eyebrow">Get In Touch</span>
    <h1 class="contact-hero-title">Contact <em>Us</em></h1>
  </div>
</section>

<!-- INFO + MAP -->
<section class="contact-info-section">
  <div class="contact-info-inner">

    <div class="contact-details">
      <span class="section-eyebrow">Our Location</span>
      <h2 class="contact-heading">Visit <em>Verduxe</em></h2>
      <div class="contact-divider"></div>

      <div class="contact-item">
        <div class="contact-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <p class="contact-label">Address</p>
          <p>Verduxe Plants Pvt. Ltd.<br>Sector 7 Dwarka, New Delhi — 110030, India</p>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.42 2 2 0 0 1 3.62 1.26h3a2 2 0 0 1 2 1.72c.12.96.36 1.9.71 2.81a2 2 0 0 1-.45 2.11L7.91 8.96a16 16 0 0 0 6 6l.96-.96a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.71a2 2 0 0 1 1.72 2.16z"/></svg>
        </div>
        <div>
          <p class="contact-label">Phone</p>
          <a href="tel:9199286971">+91 91992 86971</a>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <p class="contact-label">Email</p>
          <a href="mailto:ankitsingh.se71@gmail.com">ankitsingh.se71@gmail.com</a>
        </div>
      </div>

      <div class="contact-item">
        <div class="contact-icon">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <div>
          <p class="contact-label">Business Hours</p>
          <p>Mon – Fri, 10:30 AM – 1:00 PM IST</p>
        </div>
      </div>
    </div>

    <div class="contact-map">
      <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3503.4573215414484!2d77.0713347!3d28.586054299999994!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x390d1b17229fd6d3%3A0xb4dda3af442c011e!2sRamphal%20Chowk%20Rd%2C%20Sector%207%20Dwarka%2C%20Dwarka%2C%20Delhi!5e0!3m2!1sen!2sin!4v1693151444048!5m2!1sen!2sin"
        width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>
  </div>
</section>

<!-- CONTACT FORM -->
<section class="contact-form-section">
  <div class="contact-form-inner">
    <div class="contact-form-text">
      <span class="section-eyebrow light">Send a Message</span>
      <h2 class="contact-form-title">We'd Love to <em>Hear From You</em></h2>
      <div class="cf-divider"></div>
      <p>Have questions about our planters, customisations, or bulk orders? Drop us a message and our team will get back to you within 24 hours.</p>
    </div>

    <form id="contactForm" class="cf-form" action="/contact_us" method="post">
      <div class="cf-row">
        <div class="cf-field">
          <label for="fullName">Full Name</label>
          <input type="text" id="fullName" name="fullName" placeholder="Your full name" required>
        </div>
        <div class="cf-field">
          <label for="phoneNumber">Phone Number</label>
          <input type="tel" id="phoneNumber" name="phoneNumber" placeholder="+91 XXXXX XXXXX" required>
        </div>
      </div>
      <div class="cf-field">
        <label for="cemail">Email</label>
        <input type="email" id="cemail" name="email" placeholder="your@email.com" required>
      </div>
      <div class="cf-field">
        <label for="message">Message</label>
        <textarea id="message" name="message" placeholder="Tell us how we can help…" rows="6" required></textarea>
      </div>
      <% if (success) { %>
<div style="
    background:#d4edda;
    color:#155724;
    border:1px solid #c3e6cb;
    padding:12px 15px;
    border-radius:8px;
    margin-bottom:20px;
    text-align:center;
    font-weight:600;">
    <i class="fa-solid fa-circle-check"></i> Your message has been sent successfully!
</div>
<% } %>
      <button type="submit" class="cf-submit">Send Message</button>
      <p class="cf-success" id="cfSuccess"></p>
    </form>
  </div>
</section>

<%-include('common/footer')%>