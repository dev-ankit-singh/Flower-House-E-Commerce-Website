<%-include('common/header')%>

<style>
  .input-error{
    border:2px solid red !important;
}

.error-message{
    color:red;
    font-size:13px;
    margin-top:5px;
}
</style>

  <section class="auth-section">
    <div class="auth-left">
      <div class="auth-left-content">
        <span class="auth-eyebrow">Welcome Back</span>
        <h2 class="auth-tagline">Your space, your <em>Verduxe</em></h2>
        <p>Sign in to access your orders, wishlist, and exclusive member offers crafted just for you.</p>
        <div class="auth-perks">
          <div class="auth-perk">
            <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>View & track your orders</span>
          </div>
          <div class="auth-perk">
            <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>Access saved wishlist items</span>
          </div>
          <div class="auth-perk">
            <svg width="20" height="20" fill="none" stroke="#c9a84c" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            <span>Exclusive member discounts</span>
          </div>
        </div>
      </div>
    </div>

    <div class="auth-right">
      <div class="auth-form-card">
        <h1 class="auth-form-title">Sign In</h1>
        <p class="auth-form-sub">New to Verduxe? <a href="/registration">Create an account</a></p>

        <form action="/login" method="post" class="auth-form" id="loginForm">
          <div class="auth-field">
            <label for="LoginEmail">Email</label>
            <input type="email" name="Email" id="LoginEmail" placeholder="your@email.com" class="<%= emailError ? 'input-error' : '' %>" required>
            <% if(emailError){ %>
    <p class="error-message"><%= emailError %></p>
<% } %>
          </div>
          <div class="auth-field">
            <label for="LoginPassword">Password</label>
            <input type="password" name="Password" id="LoginPassword" placeholder="Your password" class="<%= passwordError ? 'input-error' : '' %>" required>
              <% if(passwordError){ %>
              <p class="error-message"><%= passwordError %></p>
              <% } %>
          </div>
          <p class="auth-error" id="loginError"></p>
          <button type="submit" class="auth-submit">Sign In</button>
        </form>

        <div class="auth-divider" style="margin-top:24px"><span>OR</span></div>
        <p style="text-align:center;margin-top:18px;font-size:13px;color:#888">
          <a href="#" style="color:#2d4a2d;text-decoration:underline">Forgot your password?</a>
        </p>
      </div>
    </div>
  </section>

  <%-include ('common/footer')%>